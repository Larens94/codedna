#!/usr/bin/env bash
# CodeDNA v0.8 pre-commit hook — blocks commits on missing annotations.
#
# Installation:
#   bash tools/install-hooks.sh
# Or manually:
#   cp tools/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

echo "CodeDNA v0.8 — validating staged files..."

PYTHON=""
for cmd in python3 python; do
    if command -v "$cmd" &>/dev/null; then
        PYTHON="$cmd"
        break
    fi
done

if [[ -z "$PYTHON" ]]; then
    echo "WARNING: Python not found — skipping CodeDNA validation"
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$REPO_ROOT/tools/validate_manifests.py"

if [[ ! -f "$VALIDATOR" ]]; then
    echo "WARNING: tools/validate_manifests.py not found — skipping"
    exit 0
fi

# Staged source files only (new, modified, copied)
STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(py|ts|tsx|js|jsx|go|rs|java|kt|swift|rb)$' \
    || true)

if [[ -z "$STAGED" ]]; then
    exit 0
fi

ERRORS=0
WARNED=0

for FILE in $STAGED; do
    FULL="$REPO_ROOT/$FILE"
    [[ -f "$FULL" ]] || continue

    OUTPUT=$("$PYTHON" "$VALIDATOR" "$FULL" 2>&1) || true

    if echo "$OUTPUT" | grep -q "^FAIL "; then
        ERRORS=$((ERRORS + 1))
        echo ""
        echo "FAIL  $FILE"
        echo "$OUTPUT" | grep -E "error:|warning:" | sed 's/^/      /'
    fi
done

echo ""
if [[ $ERRORS -gt 0 ]]; then
    echo "Commit blocked: $ERRORS file(s) have CodeDNA v0.8 annotation errors."
    echo ""
    echo "Minimum v0.8 header (Python):"
    echo '  """filename.py — what this file does.'
    echo ""
    echo "  exports: public_function(arg) -> return_type"
    echo "  used_by: caller.py -> caller_function"
    echo "  rules:   hard constraints an agent must never violate"
    echo '  agent:   model-id | provider | YYYY-MM-DD | session_id | what was done'
    echo '  """'
    echo ""
    echo "Run:  codedna init <path>   to auto-annotate missing files"
    echo "Run:  python tools/validate_manifests.py <path>   to check coverage"
    exit 1
fi

echo "All staged files pass CodeDNA v0.8 validation."
exit 0
