  - agent: claude-opus-4-7
    provider: anthropic
    date: 2026-04-29
    session_id: s_20260429_selfupdate
    task: "add 'codedna self-update' subcommand to upgrade the CLI itself via pip"
    changed:
      - codedna_tool/cli.py
    visited:
      - codedna_tool/cli.py
      - codedna_tool/wiki.py
      - codedna-plugin/README.md
