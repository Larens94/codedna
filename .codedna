# .codedna — CodeDNA project manifest (auto-generated by codedna manifest)
project: codedna
description: "An In-Source Communication Protocol for AI Coding Agents — spec, benchmark, tools"

packages:
  codedna_tool/:
    purpose: "Analyzes source code across multiple languages to extract and map function, class, and dependency information"
    key_files: [cli.py, swift.py, php.py, rust.py, java.py]

  examples/:
    purpose: "Provides revenue analytics and reporting with user management for financial dashboards"
    key_files: [format.py, revenue.py, routes.py, user.py, dashboard.py]

  tools/:
    purpose: "Utilities for processing agent traces, validating manifests, and extracting city data from CodeDNA sources"
    key_files: [agent_history.py, traces_to_training.py, validate_manifests.py, extract_city_data.py]

cross_cutting_patterns: {}

agent_sessions:
  - agent: claude-sonnet-4-6
    provider: anthropic
    date: 2026-03-20
    session_id: s_20260320_001
    task: "design v0.8 features: message: field, git telemetry, verification agents"
    changed:
      - SPEC.md
      - README.md
      - integrations/CLAUDE.md
